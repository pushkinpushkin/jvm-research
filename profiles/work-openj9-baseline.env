# Work-like OpenJ9 baseline profile.
# Values are based on the attached work Helm application.yml.

RUN_PROFILE=work-openj9-baseline
JVM_VARIANT=openj9
JVM_PROFILE=work-baseline
RUNTIME_IMAGE=ibm-semeru-runtimes:open-21.0.11.0-jdk-jammy

APP_PORT=8080
TZ=Europe/Moscow
SPRING_PROFILES_ACTIVE=production,kubernetes

CONTAINER_CPU_LIMIT=1
CONTAINER_MEMORY_LIMIT=1g

WORK_CPU_REQUEST=10m
WORK_CPU_LIMIT=1
WORK_MEMORY_REQUEST=512Mi
WORK_MEMORY_LIMIT=1Gi
WORK_TIMEZONE=Europe/Moscow
WORK_EXTRA_JAVA_OPTS=-Dserver.max-http-request-header-size=30000

JAVA_TOOL_OPTIONS=-Xms512m -Xmx512m -Duser.timezone=Europe/Moscow -Dserver.max-http-request-header-size=30000 -verbose:gc
