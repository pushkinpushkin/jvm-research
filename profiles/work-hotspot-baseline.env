# Production-like HotSpot baseline profile.
# Values are generic runtime limits for local JVM comparison.

RUN_PROFILE=prod-like-hotspot-baseline
JVM_VARIANT=hotspot-generic
JVM_PROFILE=prod-like-baseline
RUNTIME_IMAGE=eclipse-temurin:21-jre

APP_PORT=8080
TZ=Europe/Moscow
SPRING_PROFILES_ACTIVE=production,kubernetes

CONTAINER_CPU_LIMIT=1
CONTAINER_MEMORY_LIMIT=1g

WORK_CPU_REQUEST=10m
WORK_CPU_LIMIT=1
WORK_MEMORY_REQUEST=512Mi
WORK_MEMORY_LIMIT=1Gi
WORK_TIMEZONE=Europe/Moscow
WORK_EXTRA_JAVA_OPTS=-Dserver.max-http-request-header-size=30000

JAVA_TOOL_OPTIONS="-Xms512m -Xmx512m -Duser.timezone=Europe/Moscow -Dserver.max-http-request-header-size=30000 -XX:+PrintCommandLineFlags -Xlog:gc*,safepoint:file=/app/logs/gc.log:time,uptime,level,tags"
