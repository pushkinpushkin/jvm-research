RUN_PROFILE=hotspot-liberica-baseline
JVM_VARIANT=hotspot-liberica
JVM_PROFILE=baseline
RUNTIME_IMAGE=bellsoft/liberica-openjre-alpine:21.0.11-11
APP_PORT=8080
TZ=Europe/Moscow
SPRING_PROFILES_ACTIVE=production,kubernetes
CONTAINER_CPU_LIMIT=1
CONTAINER_MEMORY_LIMIT=1g
JAVA_TOOL_OPTIONS="-Xms512m -Xmx512m -Duser.timezone=Europe/Moscow -Dserver.max-http-request-header-size=30000"
